# flows/ios_demo.flow
# Safari iOS Demo — validates full Appium XCUITest pipeline on simulator
# Opens Safari → Google, types a search, verifies results page.
# ──────────────────────────────────────────────────────────────────────────────

# Wait for Safari + Google page to load
wait 5 seconds

# Take screenshot of Safari home
take screenshot as ios_safari_home

# Verify Google loaded
verify text "${verify_keyword}"

# Take screenshot of final state
take screenshot as ios_safari_done
