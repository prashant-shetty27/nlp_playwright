# flows/ios_demo.flow
# JustDial iOS App — Search Demo
# Element names must be recorded first with: python spy/appium_spy.py --platform ios
#
# Replace element names below with what YOU recorded.
# ──────────────────────────────────────────────────────────────────────────────

# Wait for app to load
wait 3 seconds

# Take screenshot of home screen
take screenshot as ios_home

# Tap the search box and type
tap on search_box
type "${search_term}" into search_box

# Wait for suggestions
wait 2 seconds

# Tap first suggestion
tap on first_suggestion

# Wait for results
wait 3 seconds

# Scroll down to see results
scroll down
wait 1 seconds
scroll down
wait 1 seconds

# Verify key texts appear on the results screen
verify text "${verify_keyword}"
verify text "${search_term}"
verify texts "${search_term}", "${verify_keyword}"

# Store current result count label text
store text of result_count_label as result_count

# Take screenshot of results
take screenshot as ios_results

# Scroll until footer is visible
scroll until text "JustDial" visible, scroll count 5, scroll wait 1

# Press back to return to home
press back
wait 2 seconds

take screenshot as ios_results

# Press back
press back
wait 2 seconds
