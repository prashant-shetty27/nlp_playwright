# flows/android_demo.flow
# JustDial Android App — Login Screen Smoke (uses recorded Appium locators)
#
# Recorded names used:
#   close_popup_button
#   skip_button
#   mobile_number_input
#   login_with_otp_button

wait 3 seconds
take screenshot as android_launch

# Dismiss Google phone number chooser popup (if visible in this build)
click if exists close_popup_button
wait 1 seconds

# Handle optional Android permission dialogs (may appear before/after skip)
click if exists permission_while_using_button
wait 1 seconds
click if exists permission_allow_button
wait 1 seconds

# Continue on app login screen if skip is shown
click if exists skip_button
wait 1 seconds

type if exists "9987996046" into mobile_number_input
wait 1 seconds

click if exists login_with_otp_button
wait 2 seconds

take screenshot as android_after_login_tap
