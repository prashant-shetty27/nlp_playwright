# ============================================================
# Environment Configuration Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ─── Platform ───────────────────────────────────────────────────────────────
# Options: web | mobile | android | ios | hybrid
PLATFORM=web

# ─── Browser ────────────────────────────────────────────────────────────────
HEADLESS=false
ACTION_TIMEOUT_MS=15000
NAVIGATION_TIMEOUT_MS=30000
DEFAULT_SCROLL_COUNT=20
WAIT_TIMEOUT_MS=3000

# ─── Retry ──────────────────────────────────────────────────────────────────
RETRY_MAX_ATTEMPTS=3
RETRY_DELAY_SECONDS=2.0

# ─── Auth Credentials ───────────────────────────────────────────────────────
# Pattern: AUTH_<KEY>_DOMAIN / AUTH_<KEY>_USERNAME / AUTH_<KEY>_PASSWORD
# Add one block per site that requires HTTP auth or login.
AUTH_STAGING2_DOMAIN=your-staging-domain.example.com
AUTH_STAGING2_USERNAME=your_username_here
AUTH_STAGING2_PASSWORD=your_password_here

# ─── Mobile Web Emulation ───────────────────────────────────────────────────
# Uncomment to enable mobile device emulation in the web adapter
# MOBILE_DEVICE_EMULATION=iPhone 14
# MOBILE_BROWSER_TYPE=chromium
# MOBILE_USER_AGENT=

# ─── Appium (Android / iOS / Hybrid) ────────────────────────────────────────
# Uncomment when using android / ios / hybrid adapters
# APPIUM_SERVER_URL=http://localhost:4723
# ANDROID_CAPABILITIES={"platformName":"Android","deviceName":"emulator-5554"}
# IOS_CAPABILITIES={"platformName":"iOS","deviceName":"iPhone 14","udid":"auto"}
# HYBRID_CAPABILITIES={}
# ─── Slack Notifications ───────────────────────────────────────────────
# Set NOTIFY_ON_SLACK=true and add your Incoming Webhook URL
# Create one at: https://api.slack.com/messaging/webhooks
NOTIFY_ON_SLACK=false
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#test-results
SLACK_USERNAME=NLP-Playwright Bot
SLACK_ICON_EMOJI=:robot_face:

# ─── Email Notifications (future — stub ready) ────────────────────────────
# NOTIFY_ON_EMAIL=false
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_SENDER=yourbot@example.com
# EMAIL_PASSWORD=your_app_password
# EMAIL_RECIPIENTS=qa@example.com,manager@example.com