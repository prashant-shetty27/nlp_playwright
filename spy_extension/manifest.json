{
  "manifest_version": 3,
  "name": "ML Codeless Spy",
  "version": "1.0",
  "description": "Captures element DNA for ML-driven test automation.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true
    }
  ]
}